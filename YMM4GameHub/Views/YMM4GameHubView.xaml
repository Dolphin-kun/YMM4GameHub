<UserControl x:Class="YMM4GameHub.Views.YMM4GameHubView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:YMM4GameHub.Views"
             xmlns:vm="clr-namespace:YMM4GameHub.ViewModels"
             xmlns:core="clr-namespace:YMM4GameHub.Core.Commons;assembly=YMM4GameHub.Core"
            xmlns:coreControls="clr-namespace:YMM4GameHub.Core.Controls;assembly=YMM4GameHub.Core"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <local:ProgressToWidthConverter x:Key="ProgressToWidthConverter"/>
        <local:ProgressToColorConverter x:Key="ProgressToColorConverter"/>

        <Style x:Key="CategoryBadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="#E1F5FE"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="24,12"/>
            <Setter Property="Background" Value="#007AFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LevelCardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#F0F4FF"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsGainingPoints}" Value="True">
                    <Setter Property="Background" Value="#E8F5E9"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsRecentlyPenalized}" Value="True">
                    <Setter Property="Background" Value="#FFEBEE"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ヘッダーとプロフィール -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="YMM4 Game Hub" FontSize="28" FontWeight="ExtraBold" Foreground="#1D1D1F"/>
                <TextBlock Text="最新のゲームをダウンロードしてオンライン対戦" FontSize="12" Foreground="#888888" Margin="2,2,0,0"/>
            </StackPanel>

            <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal">

                <!-- Level Card with Progress Bar -->
                <Button Command="{Binding ToggleLevelDetailCommand}" Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <ContentPresenter/>
                        </ControlTemplate>
                    </Button.Template>
                    <Border Style="{StaticResource LevelCardBorderStyle}" CornerRadius="10" Padding="12,6" Margin="0,0,16,0" VerticalAlignment="Center" MinWidth="130">
                        <StackPanel>
                            <!-- Level number row -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,4">
                                <TextBlock Text="⭐ Lv." Foreground="#4A6CF7" FontWeight="Bold" FontSize="12" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Level}" Foreground="#4A6CF7" FontWeight="Bold" FontSize="16" Margin="2,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <!-- Progress bar: 0% = empty, 100% = level up -->
                            <Grid Height="6" ToolTip="{Binding LevelProgressPercent, StringFormat={}{0:F1}%}">
                                <!-- 背景トラック -->
                                <Border Background="#D0D8FF" CornerRadius="3"/>
                                <!-- 進捗 -->
                                <Border HorizontalAlignment="Left" CornerRadius="3"
                                        Width="{Binding LevelProgressPercent, Converter={StaticResource ProgressToWidthConverter}}"
                                        Background="{Binding LevelProgressPercent, Converter={StaticResource ProgressToColorConverter}}"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Button>

                <!-- Level Detail Popup -->
                <Popup IsOpen="{Binding IsLevelDetailOpen}" StaysOpen="False" Placement="Bottom" AllowsTransparency="True">
                    <Border Background="White" BorderBrush="#EEEEEE" BorderThickness="1" CornerRadius="12" Padding="16" Margin="5">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="20" Opacity="0.15" ShadowDepth="4"/>
                        </Border.Effect>
                        <StackPanel MinWidth="180">
                            <TextBlock Text="レベル詳細" FontWeight="Bold" FontSize="14" Margin="0,0,0,12" Foreground="#1D1D1F"/>
                            
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="現在のポイント:" Foreground="#888888" FontSize="12"/>
                                <TextBlock Text="{Binding LevelPoints, StringFormat={}{0:F1} pts}" HorizontalAlignment="Right" FontWeight="Bold" FontSize="12" Foreground="#4A6CF7"/>
                            </Grid>
                            
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="次レベルまで:" Foreground="#888888" FontSize="12"/>
                                <TextBlock Text="{Binding RemainingPoints, StringFormat={}{0:F1} pts}" HorizontalAlignment="Right" FontWeight="Bold" FontSize="12" Foreground="#FF9500"/>
                            </Grid>
                            
                            <Separator Background="#F5F5F7" Margin="0,4,0,10"/>
                            
                            <Grid>
                                <TextBlock Text="次レベル閾値:" Foreground="#888888" FontSize="11"/>
                                <TextBlock Text="{Binding NextLevelThreshold, StringFormat={}{0:F1} pts}" HorizontalAlignment="Right" FontSize="11"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Popup>

                <StackPanel Orientation="Horizontal" Margin="0,0,20,0" VerticalAlignment="Center">
                    <TextBlock Text="👥 マッチング中:" Foreground="#888888" FontSize="11" Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding TotalMatchingUsers}" Foreground="#FF9500" FontWeight="Bold" FontSize="11"/>
                    <TextBlock Text="人  |  " Foreground="#888888" FontSize="11"/>
                    <TextBlock Text="🟢 オンライン:" Foreground="#888888" FontSize="11" Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding TotalOnlineUsers}" Foreground="#34C759" FontWeight="Bold" FontSize="11"/>
                    <TextBlock Text="人" Foreground="#888888" FontSize="11"/>
                </StackPanel>

                <TextBlock Text="👤 ニックネーム:" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="#1D1D1F" FontSize="12"/>
                <coreControls:InformationButton Description="オンライン対戦で表示されるニックネームです。お互いに気持ちよくプレイできるよう、適切な名前を設定しましょう。" Margin="0,0,4,0" VerticalAlignment="Center"/>
                <TextBox Text="{Binding UserSettings.UserName, UpdateSourceTrigger=PropertyChanged}" Width="120" Padding="5,3" BorderThickness="1" BorderBrush="#E5E5E7" VerticalAlignment="Center" FontSize="12"/>
            </StackPanel>
        </Grid>

        <ListBox Grid.Row="1" 
                 ItemsSource="{Binding AvailableGames}" 
                 SelectedItem="{Binding SelectedGame}"
                 BorderThickness="0"
                 Background="Transparent"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="10"/>
                    <Setter Property="Background" Value="White"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border x:Name="Border" 
                                        Background="White" 
                                        CornerRadius="12" 
                                        BorderThickness="1" 
                                        BorderBrush="#EEEEEE"
                                        Width="220" Height="280">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="15" Direction="-90" RenderingBias="Quality" ShadowDepth="2" Opacity="0.1"/>
                                    </Border.Effect>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="140"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <!-- サムネイル -->
                                        <Border Grid.Row="0" CornerRadius="12,12,0,0" Background="#F5F5F7">
                                            <Grid>
                                                <TextBlock Text="🎮" FontSize="48" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.5"/>
                                                <Image Source="{Binding ThumbnailUrl}" Stretch="UniformToFill" Margin="0" RenderOptions.BitmapScalingMode="HighQuality"/>
                                            </Grid>
                                        </Border>

                                        <StackPanel Grid.Row="1" Margin="15">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Category}" FontSize="10" Foreground="#0066CC" FontWeight="Bold" Margin="0,0,0,4"/>
                                                <Border Grid.Column="1" Background="#E1F5FE" CornerRadius="4" Padding="4,2">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsInstalled}" Value="False">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="未インストール" FontSize="9" Foreground="#0288D1" FontWeight="Bold"/>
                                                </Border>

                                                <!-- アップデートありバッジ -->
                                                <Border Grid.Column="1" Background="#FFF9C4" CornerRadius="4" Padding="4,2">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsUpdateAvailable}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="更新あり" FontSize="9" Foreground="#F57F17" FontWeight="Bold"/>
                                                </Border>

                                                <!-- 待機人数バッジ -->
                                                <Border Grid.Column="1" Background="#FFE0B2" CornerRadius="4" Padding="4,2" Margin="0,0,0,0">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding WaitingCount}" Value="0">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="対戦待機:" FontSize="9" Foreground="#FB8C00" FontWeight="Bold"/>
                                                        <TextBlock Text="{Binding WaitingCount}" FontSize="9" Foreground="#FB8C00" FontWeight="Bold" Margin="2,0,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                            
                                            <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="Bold" Foreground="#1D1D1F"/>
                                            
                                            <TextBlock Margin="0,5,0,0">
                                                <Run Text="v" FontSize="11" Foreground="#888888"/>
                                                <Run Text="{Binding Version, Mode=OneWay}" FontSize="12" Foreground="#888888"/>
                                            </TextBlock>
                                            
                                            <TextBlock Text="{Binding Author, StringFormat='@{0}'}" FontSize="12" Foreground="#888888" Margin="0,2,0,0"/>
                                        </StackPanel>

                                        <!-- 選択時のハイライト -->
                                        <Border x:Name="Highlight" CornerRadius="12" BorderThickness="3" BorderBrush="#0066CC" Visibility="Hidden"/>
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Highlight" Property="Visibility" Value="Visible"/>
                                        <Setter TargetName="Border" Property="BorderBrush" Value="#0066CC"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>

        <!-- 詳細オーバーレイ -->
        <Grid Grid.RowSpan="2" Margin="-20" Panel.ZIndex="100">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <!-- SelectedGame が null のときに非表示 -->
                        <DataTrigger Binding="{Binding SelectedGame}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            
            <!-- 背景フェード -->
            <Border Background="#44000000">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding CancelLaunchCommand}"/>
                </Border.InputBindings>
            </Border>

            <!-- 詳細カード -->
            <Border Background="White" CornerRadius="24" Width="800" MaxHeight="550" Height="Auto" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="40" Color="Black" Opacity="0.2" ShadowDepth="0"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左側: サムネイルと基本情報 -->
                    <Border Grid.Column="0" Background="#FBFBFD" CornerRadius="24,0,0,24" Padding="30">
                        <StackPanel>
                            <Border CornerRadius="16" Height="200" Background="#F5F5F7" Margin="0,0,0,20">
                                <Grid>
                                    <TextBlock Text="🎮" FontSize="64" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.5"/>
                                    <Image Source="{Binding SelectedGame.ThumbnailUrl}" Stretch="UniformToFill" Margin="0" RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Grid>
                            </Border>

                            <TextBlock Text="{Binding SelectedGame.Name}" FontSize="24" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding SelectedGame.Category}" FontSize="12" Foreground="#0066CC" FontWeight="Bold" Margin="0,0,0,15"/>

                            <Grid Margin="0,0,0,10">
                                <TextBlock Text="バージョン" Foreground="#888888" FontSize="11"/>
                                <TextBlock Text="{Binding SelectedGame.Version}" HorizontalAlignment="Right" FontSize="11"/>
                            </Grid>
                            <Grid Margin="0,0,0,10">
                                <TextBlock Text="開発者" Foreground="#888888" FontSize="11"/>
                                <TextBlock Text="{Binding SelectedGame.Author}" HorizontalAlignment="Right" FontSize="11"/>
                            </Grid>
                            <Grid Margin="0,0,0,10">
                                <TextBlock Text="プレイ人数" Foreground="#888888" FontSize="11"/>
                                <TextBlock Text="{Binding SelectedGame.PlayerCountText}" HorizontalAlignment="Right" FontSize="11" FontWeight="Bold"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- 右側: アクションメイン -->
                    <Grid Grid.Column="1" Margin="40" VerticalAlignment="Center">
                        <StackPanel>
                            <!-- 未インストール -->
                            <StackPanel>
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedGame.IsInstalled}" Value="False">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="このゲームはまだインストールされていません" HorizontalAlignment="Center" Margin="0,0,0,20" Foreground="#888888"/>
                                <Button Content="インストールして遊ぶ" Command="{Binding DownloadCommand}" Style="{StaticResource ActionButtonStyle}" HorizontalAlignment="Stretch" Height="60" Background="#0066CC" FontSize="18"/>
                            </StackPanel>

                            <!-- インストール済み -->
                            <StackPanel Visibility="{Binding SelectedGame.IsInstalled, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <!-- シングルプレイ -->
                                <StackPanel Visibility="{Binding SelectedGame.IsSinglePlaySupported, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,0,0,0">
                                    <TextBlock Text="ソロプレイ" FontSize="14" FontWeight="Bold" Margin="0,0,0,10" Foreground="#1D1D1F"/>
                                    <Button Content="🎮 1人で遊ぶ (オフライン)" 
                                            Command="{Binding SelectLaunchModeCommand}" 
                                            CommandParameter="{x:Static core:GameLaunchMode.Offline}"
                                            Style="{StaticResource ActionButtonStyle}" 
                                            Background="#34C759"
                                            Height="60" FontSize="16"
                                            Margin="0,0,0,30"/>
                                </StackPanel>

                                <!-- マルチプレイ -->
                                <StackPanel Visibility="{Binding SelectedGame.IsMultiplaySupported, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="オンライン対戦" FontSize="14" FontWeight="Bold" Margin="0,0,0,10" Foreground="#1D1D1F"/>
                                    
                                    <Grid Margin="0,0,0,15">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- マッチング中/キャンセルボタンの切り替え -->
                                        <Button Height="60" FontSize="16" Margin="0">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
                                                    <Setter Property="Content" Value="オンラインマッチ"/>
                                                    <Setter Property="Command" Value="{Binding RandomMatchCommand}"/>
                                                    <Setter Property="Background" Value="#FF9500"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsProcessing}" Value="True">
                                                            <Setter Property="Content" Value="マッチングをキャンセル"/>
                                                            <Setter Property="Command" Value="{Binding CancelMatchmakingCommand}"/>
                                                            <Setter Property="Background" Value="#FF3B30"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        
                                        <TextBlock Grid.Column="1" Text="{Binding MatchStatus}" FontSize="11" VerticalAlignment="Center" Margin="10,0,0,0" FontWeight="Bold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#FF9500"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsProcessing}" Value="True">
                                                            <Setter Property="Foreground" Value="#FF3B30"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>

                                    <UniformGrid Columns="2" Margin="0,0,0,15">
                                        <Button Content="ルームを作る" Command="{Binding CreateRoomCommand}" Style="{StaticResource ActionButtonStyle}" Background="#F5F5F7" Foreground="#1D1D1F" Margin="0,0,5,0" Height="50"/>
                                        <Button Content="ルームに入室" Command="{Binding JoinRoomCommand}" Style="{StaticResource ActionButtonStyle}" Background="#F5F5F7" Foreground="#1D1D1F" Margin="5,0,0,0" Height="50"/>
                                    </UniformGrid>
                                    
                                    <DockPanel LastChildFill="True">
                                        <TextBlock Text="ルームID:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#666666" FontSize="11"/>
                                        <TextBox Text="{Binding RoomId, UpdateSourceTrigger=PropertyChanged}" Padding="10,8" BorderThickness="1" BorderBrush="#E5E5E7"/>
                                    </DockPanel>
                                </StackPanel>

                                <!-- アップデート -->
                                <Button Content="最新バージョンが利用可能です" Command="{Binding DownloadCommand}" 
                                        Style="{StaticResource ActionButtonStyle}" Background="#FFF9C4" Foreground="#F57F17"
                                        Visibility="{Binding SelectedGame.IsUpdateAvailable, Converter={StaticResource BooleanToVisibilityConverter}}"
                                        Margin="0,20,0,0" Height="40" Padding="10,5"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
