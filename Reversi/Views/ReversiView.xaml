<UserControl x:Class="Reversi.Views.ReversiView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="500">
    <UserControl.Resources>
        <Style x:Key="BoardCellButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0.5"/>
            <Setter Property="BorderBrush" Value="#1B3A1B"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Background="{TemplateBinding Background}">
                            <Grid>
                                <Border x:Name="Overlay" Opacity="0" Background="White"/>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Overlay" Property="Opacity" Value="0.2"/>
                                <Setter TargetName="Overlay" Property="Background" Value="Cyan"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    
    <Grid Background="#1B3A1B">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Background="#122612" BorderBrush="#2D5A27" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="PLAYERS" Foreground="#FFD700" FontWeight="Bold" Margin="10" HorizontalAlignment="Center" FontSize="14"/>
                <ItemsControl Grid.Row="1" ItemsSource="{Binding AllPlayers}" Margin="5">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#1B3A1B" Margin="2" Padding="10" CornerRadius="4">
                                <StackPanel>
                                    <TextBlock Text="{Binding Profile.Name}" Foreground="White" FontWeight="SemiBold" FontSize="14"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <TextBlock Text="Ping: " Foreground="#BDC3C7" FontSize="10"/>
                                        <TextBlock Text="{Binding Latency, StringFormat='{}{0}ms'}" Foreground="#FFD700" FontSize="10" FontWeight="Bold"/>
                                    </StackPanel>
                                    <!-- Future: Icon, Level -->
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="10">
            <TextBlock Text="YMM4 REVERSI" HorizontalAlignment="Center" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,5"/>
            <TextBlock x:Name="StatusText" Text="{Binding Status}" HorizontalAlignment="Center" FontSize="16" Foreground="#FFD700" />
        </StackPanel>

        <Viewbox Grid.Row="1" Margin="10" Stretch="Uniform">
            <Border Background="#2D5A27" BorderBrush="#1B3A1B" BorderThickness="4" SnapsToDevicePixels="True">
                <UniformGrid x:Name="BoardGrid" Rows="8" Columns="8" Width="400" Height="400"/>
            </Border>
        </Viewbox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
            <StackPanel Margin="10,5">
                <TextBlock Text="黒 (Black)" Foreground="White" HorizontalAlignment="Center" FontSize="12"/>
                <Ellipse Width="24" Height="24" Fill="Black" Stroke="White" StrokeThickness="1" Margin="2"/>
            </StackPanel>
            <StackPanel Margin="10,5">
                <TextBlock Text="白 (White)" Foreground="White" HorizontalAlignment="Center" FontSize="12"/>
                <Ellipse Width="24" Height="24" Fill="White" Stroke="Gray" StrokeThickness="1" Margin="2"/>
            </StackPanel>
        </StackPanel>

        <!-- Result Overlay -->
        <Grid x:Name="ResultOverlay" Grid.RowSpan="3" Grid.ColumnSpan="2" Background="#AA000000" Visibility="Collapsed">
            <Border Background="#2D5A27" BorderBrush="White" BorderThickness="2" CornerRadius="10" 
                    VerticalAlignment="Center" HorizontalAlignment="Center" Padding="30">
                <StackPanel>
                    <TextBlock Text="GAME OVER" Foreground="White" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                    <TextBlock x:Name="ResultText" Foreground="#FFD700" FontSize="20" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                    <Button Content="閉じる" Padding="20,10" x:Name="CloseResultButton" Click="CloseResultButton_Click"
                            Background="#1B3A1B" Foreground="White" FontWeight="Bold" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
        </Grid>
    </Grid>
</UserControl>
