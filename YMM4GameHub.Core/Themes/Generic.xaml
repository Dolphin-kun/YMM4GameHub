<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:YMM4GameHub.Core.Controls">
    
    <Style TargetType="{x:Type local:CardControl}">
        <Setter Property="Width" Value="60"/>
        <Setter Property="Height" Value="90"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:CardControl}">
                    <Border x:Name="BaseBorder" Background="White" BorderBrush="Gray" BorderThickness="1" CornerRadius="5">
                        <Grid>
                            <!-- Face Up -->
                            <Grid x:Name="FaceGrid">
                                <StackPanel Margin="3" HorizontalAlignment="Left" VerticalAlignment="Top">
                                    <TextBlock x:Name="SuitText" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="NumberText" Text="{Binding Number, RelativeSource={RelativeSource TemplatedParent}}" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock x:Name="CenterText" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                            
                            <!-- Face Down -->
                            <Border x:Name="BackBorder" Background="#2C3E50" Visibility="Collapsed" CornerRadius="4" Margin="2">
                                <Border BorderBrush="#34495E" BorderThickness="2" Margin="3" CornerRadius="2">
                                    <Viewbox Margin="2">
                                        <TextBlock Text="YMM4" Foreground="White" Opacity="0.3" FontWeight="Bold"/>
                                    </Viewbox>
                                </Border>
                            </Border>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- Suit Settings -->
                        <Trigger Property="Suit" Value="Hearts">
                            <Setter Property="Foreground" Value="Red"/>
                            <Setter TargetName="SuitText" Property="Text" Value="♥"/>
                            <Setter TargetName="CenterText" Property="Text" Value="♥"/>
                        </Trigger>
                        <Trigger Property="Suit" Value="Diamonds">
                            <Setter Property="Foreground" Value="Red"/>
                            <Setter TargetName="SuitText" Property="Text" Value="♦"/>
                            <Setter TargetName="CenterText" Property="Text" Value="♦"/>
                        </Trigger>
                        <Trigger Property="Suit" Value="Clubs">
                            <Setter TargetName="SuitText" Property="Text" Value="♣"/>
                            <Setter TargetName="CenterText" Property="Text" Value="♣"/>
                        </Trigger>
                        <Trigger Property="Suit" Value="Spades">
                            <Setter TargetName="SuitText" Property="Text" Value="♠"/>
                            <Setter TargetName="CenterText" Property="Text" Value="♠"/>
                        </Trigger>
                        
                        <!-- Number Settings -->
                        <Trigger Property="Number" Value="1">
                            <Setter TargetName="NumberText" Property="Text" Value="A"/>
                        </Trigger>
                        <Trigger Property="Number" Value="11">
                            <Setter TargetName="NumberText" Property="Text" Value="J"/>
                        </Trigger>
                        <Trigger Property="Number" Value="12">
                            <Setter TargetName="NumberText" Property="Text" Value="Q"/>
                        </Trigger>
                        <Trigger Property="Number" Value="13">
                            <Setter TargetName="NumberText" Property="Text" Value="K"/>
                        </Trigger>
                        <DataTrigger Binding="{Binding Number, RelativeSource={RelativeSource Self}, Converter={x:Null}}" Value="null">
                            <!-- This is a placeholder for non-special numbers -->
                        </DataTrigger>
                        
                        <!-- Default Number display (when not J,Q,K,A) -->
                        <!-- Simple way: TemplateBinding in the TextBlock itself but triggers override for special cases -->
                        
                        <!-- Face Down State -->
                        <Trigger Property="IsFaceUp" Value="False">
                            <Setter TargetName="FaceGrid" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="BackBorder" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        
                        <!-- Playable State -->
                        <Trigger Property="IsPlayable" Value="True">
                            <Setter TargetName="BaseBorder" Property="BorderBrush" Value="Cyan"/>
                            <Setter TargetName="BaseBorder" Property="BorderThickness" Value="2"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style TargetType="{x:Type local:InformationButton}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="4"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:InformationButton}">
                    <Grid>
                        <Border x:Name="Border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="10" 
                                Width="20" Height="20">
                            <TextBlock Text="ℹ️" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center" 
                                       FontSize="12"/>
                        </Border>
                        
                        <Popup x:Name="DescriptionPopup" 
                               IsOpen="{Binding IsDescriptionOpen, RelativeSource={RelativeSource TemplatedParent}}" 
                               StaysOpen="False" 
                               Placement="Bottom" 
                               AllowsTransparency="True">
                            <Border Background="White" 
                                    BorderBrush="#EEEEEE" 
                                    BorderThickness="1" 
                                    CornerRadius="8" 
                                    Padding="12,8" 
                                    MaxWidth="250"
                                    Margin="5">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" Opacity="0.1" ShadowDepth="2"/>
                                </Border.Effect>
                                <TextBlock Text="{Binding Description, RelativeSource={RelativeSource TemplatedParent}}" 
                                           FontSize="12" 
                                           Foreground="#333333" 
                                           TextWrapping="Wrap"/>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="#F0F0F0"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
